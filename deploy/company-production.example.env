# Copy to .env.company-production and fill values from the deployment secret manager.
# This template is for the serious company target: Postgres documents/chunks,
# native pgvector text embeddings, and Postgres source-sync ledgers.

RAG_APP_PROFILE_PRESET=generic-docs
RAG_APP_EMBEDDING_MODE=required
RAG_APP_VISUAL_EMBEDDING_MODE=disabled
RAG_APP_RERANK_MODE=auto
RAG_APP_GROUNDING_JUDGE_MODE=required

RAG_COMPANY_MODULE_PATH=dist/company/examples/acme-support.company.js
RAG_COMPANY_PROFILE_EXPORT=acmeSupportCompanyProfile
RAG_COMPANY_ADAPTER_PACK_EXPORTS=acmeSupportAdapterPack
RAG_COMPANY_USE_CASE_ID=support
RAG_COMPANY_PACK_CONTRACT_MODE=required
RAG_COMPANY_CONTRACT_TENANT_ID=tenant_acme
RAG_COMPANY_CONTRACT_NAMESPACE_IDS=acme-support
RAG_COMPANY_CONTRACT_ROLES=support
RAG_COMPANY_CONTRACT_TAGS=trusted,contract-test

RAG_HTTP_HOST=0.0.0.0
RAG_HTTP_PORT=8787
RAG_HTTP_MAX_BODY_BYTES=131072
RAG_HTTP_AUTH_MODE=required
RAG_HTTP_AUTH_HEADER=authorization
RAG_HTTP_AUTH_TOKEN_ENV=RAG_HTTP_AUTH_TOKEN
RAG_HTTP_AUTH_TOKEN=replace_me_with_high_entropy_token
RAG_HTTP_RATE_LIMIT_MODE=enabled
RAG_HTTP_RATE_LIMIT_WINDOW_MS=60000
RAG_HTTP_RATE_LIMIT_MAX_REQUESTS=60
RAG_HTTP_RATE_LIMIT_MAX_KEYS=10000
RAG_HTTP_LOG_MODE=json
RAG_HTTP_REQUEST_ID_HEADER=x-request-id
RAG_HTTP_READINESS_PATH=/ready
RAG_HTTP_METRICS_PATH=/metrics

RAG_INDEX_KIND=postgres
RAG_SOURCE_SYNC_LEDGER_KIND=postgres
RAG_VECTOR_KIND=postgres
RAG_VECTOR_DIMENSIONS=1536
RAG_VISUAL_VECTOR_KIND=none
RAG_POSTGRES_URL_ENV=RAG_DATABASE_URL
RAG_DATABASE_URL=postgres://rag:replace_me@postgres:5432/rag
RAG_POSTGRES_SCHEMA=rag_core

RAG_MODEL_PROVIDER=openai-compatible
RAG_MODEL_MODEL_NAME=company-answer-model
RAG_MODEL_ENDPOINT=https://provider.example.test/v1/chat/completions
RAG_MODEL_API_KEY_ENV=ANSWER_MODEL_API_KEY
ANSWER_MODEL_API_KEY=replace_me
RAG_MODEL_TIMEOUT_MS=30000
RAG_MODEL_MAX_RETRIES=2
RAG_MODEL_BACKOFF_MS=250

RAG_EMBEDDING_PROVIDER=openai-compatible
RAG_EMBEDDING_MODEL_NAME=company-embedding-model
RAG_EMBEDDING_ENDPOINT=https://provider.example.test/v1/embeddings
RAG_EMBEDDING_API_KEY_ENV=EMBEDDING_MODEL_API_KEY
EMBEDDING_MODEL_API_KEY=replace_me
RAG_EMBEDDING_DIMENSIONS=1536
RAG_EMBEDDING_TIMEOUT_MS=30000
RAG_EMBEDDING_MAX_RETRIES=2
RAG_EMBEDDING_BACKOFF_MS=250

RAG_GROUNDING_JUDGE_PROVIDER=openai-compatible
RAG_GROUNDING_JUDGE_MODEL_NAME=company-grounding-judge-model
RAG_GROUNDING_JUDGE_ENDPOINT=https://provider.example.test/v1/chat/completions
RAG_GROUNDING_JUDGE_API_KEY_ENV=GROUNDING_JUDGE_API_KEY
GROUNDING_JUDGE_API_KEY=replace_me
RAG_GROUNDING_JUDGE_TIMEOUT_MS=30000
RAG_GROUNDING_JUDGE_MAX_RETRIES=2
RAG_GROUNDING_JUDGE_BACKOFF_MS=250

# Optional model reranker for profiles that set retrieval.rerankMode=model.
# RAG_RERANK_PROVIDER=openai-compatible
# RAG_RERANK_MODEL_NAME=company-rerank-model
# RAG_RERANK_ENDPOINT=https://provider.example.test/v1/chat/completions
# RAG_RERANK_API_KEY_ENV=RERANK_MODEL_API_KEY
# RERANK_MODEL_API_KEY=replace_me
