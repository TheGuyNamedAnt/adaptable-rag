# Copy to .env.smoke and replace placeholders with real provider endpoints/secrets.
# This file is intentionally not enough to pass until real providers are configured.

RAG_APP_PROFILE_PRESET=generic-docs
RAG_APP_EMBEDDING_MODE=required
RAG_APP_VISUAL_EMBEDDING_MODE=disabled
RAG_APP_RERANK_MODE=disabled
RAG_APP_GROUNDING_JUDGE_MODE=disabled

RAG_SMOKE_REQUIRED_PROVIDERS=model,embedding

RAG_INDEX_KIND=memory
RAG_VECTOR_KIND=memory
RAG_VECTOR_DIMENSIONS=1536
RAG_VISUAL_VECTOR_KIND=none

RAG_HTTP_AUTH_MODE=disabled
RAG_HTTP_RATE_LIMIT_MODE=disabled
RAG_HTTP_LOG_MODE=disabled

RAG_MODEL_PROVIDER=openai-compatible
RAG_MODEL_MODEL_NAME=gpt-4.1-mini
RAG_MODEL_ENDPOINT=https://api.openai.com/v1/chat/completions
RAG_MODEL_API_KEY_ENV=OPENAI_API_KEY

RAG_EMBEDDING_PROVIDER=openai-compatible
RAG_EMBEDDING_MODEL_NAME=text-embedding-3-small
RAG_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings
RAG_EMBEDDING_API_KEY_ENV=OPENAI_API_KEY
RAG_EMBEDDING_DIMENSIONS=1536

# Optional reranker smoke:
# RAG_APP_RERANK_MODE=required
# RAG_SMOKE_REQUIRED_PROVIDERS=model,embedding,rerank
# RAG_RERANK_PROVIDER=openai-compatible
# RAG_RERANK_MODEL_NAME=gpt-4.1-mini
# RAG_RERANK_ENDPOINT=https://api.openai.com/v1/chat/completions
# RAG_RERANK_API_KEY_ENV=OPENAI_API_KEY

