# RAG_SMOKE_REQUIRED_PROVIDERS=model,embedding,grounding_judge
# RAG_GROUNDING_JUDGE_PROVIDER=openai-compatible
# RAG_GROUNDING_JUDGE_MODEL_NAME=gpt-4.1-mini
# RAG_GROUNDING_JUDGE_ENDPOINT=https://api.openai.com/v1/chat/completions
# RAG_GROUNDING_JUDGE_API_KEY_ENV=OPENAI_API_KEY
