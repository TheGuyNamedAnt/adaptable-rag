# Copy to .env for local Docker runs. Keep real secrets out of git.

RAG_APP_PROFILE_PRESET=generic-docs
RAG_APP_EMBEDDING_MODE=disabled
RAG_APP_VISUAL_EMBEDDING_MODE=disabled
RAG_APP_RERANK_MODE=disabled
# Grounding judge mode controls the optional faithfulness judge:
# disabled = do not load a judge, auto = load when RAG_GROUNDING_JUDGE_* env is present,
# required = fail startup unless judge provider config is complete.
RAG_APP_GROUNDING_JUDGE_MODE=disabled

# Used by `adaptable-rag ingest` for profile sources that use the local-files adapter.
RAG_LOCAL_FILES_SOURCES_PATH=/data/local-files.sources.json
# Optional: used by `adaptable-rag ingest` for profile sources that use the
# built-in approved_knowledge_artifact adapter.
# RAG_APPROVED_KNOWLEDGE_ARTIFACTS_PATH=/data/approved-knowledge.sources.json
#
# Company deployment module. Use this for plug-and-play company deployments
# where the compiled module exports one CompanyDeploymentManifest.
# RAG_COMPANY_MODULE_PATH=/app/dist/company/examples/acme-support.company.js
# RAG_COMPANY_DEPLOYMENT_EXPORT=acmeSupportDeployment
# Optional legacy override for profile-only modules:
# RAG_COMPANY_PROFILE_EXPORT=acmeSupportCompanyProfile
# RAG_COMPANY_ADAPTER_PACK_EXPORTS=acmeSupportAdapterPack
# RAG_COMPANY_USE_CASE_ID=support
# RAG_COMPANY_PACK_CONTRACT_MODE=required

RAG_HTTP_HOST=0.0.0.0
RAG_HTTP_PORT=8787
RAG_HTTP_MAX_BODY_BYTES=131072
RAG_HTTP_AUTH_MODE=required
RAG_HTTP_AUTH_HEADER=authorization
RAG_HTTP_AUTH_TOKEN_ENV=RAG_HTTP_AUTH_TOKEN
RAG_HTTP_AUTH_TOKEN=replace_me_with_high_entropy_token
# Production identity gateways should use signed principal headers instead of body-provided roles.
# RAG_PRINCIPAL_MODE=signed_header
# RAG_PRINCIPAL_SIGNING_SECRET_ENV=RAG_PRINCIPAL_SIGNING_SECRET
# RAG_PRINCIPAL_MAX_AGE_MS=300000
# RAG_PRINCIPAL_CLOCK_SKEW_MS=60000
# RAG_PRINCIPAL_ISSUER=identity-gateway
RAG_HTTP_RATE_LIMIT_MODE=enabled
RAG_HTTP_RATE_LIMIT_WINDOW_MS=60000
RAG_HTTP_RATE_LIMIT_MAX_REQUESTS=60
RAG_HTTP_RATE_LIMIT_MAX_KEYS=10000
# Set only when a trusted reverse proxy strips untrusted client IP headers.
# RAG_HTTP_CLIENT_IP_HEADER=x-forwarded-for
RAG_HTTP_LOG_MODE=json
RAG_HTTP_REQUEST_ID_HEADER=x-request-id
RAG_HTTP_READINESS_PATH=/ready
RAG_HTTP_METRICS_PATH=/metrics

# Optional admin UI. The admin app reads health/ready/metrics over HTTP and
# uses the compiled CLI for Postgres-backed inspection views.
# npm run admin:dev starts the RAG HTTP service and admin UI together.
# RAG_ADMIN_STACK_RAG_MODE=managed
# RAG_ADMIN_STACK_WORKER=disabled
# RAG_ADMIN_HOST=127.0.0.1
# RAG_ADMIN_PORT=8788
# RAG_ADMIN_RAG_BASE_URL=http://127.0.0.1:8787
# Optional: bearer token used by the admin app when the RAG HTTP service has auth enabled.
# RAG_ADMIN_RAG_AUTH_TOKEN_ENV=RAG_HTTP_AUTH_TOKEN
# RAG_ADMIN_REPO_ROOT=/app
# RAG_ADMIN_CLI_PATH=/app/dist/runtime/production-cli.js
# RAG_ADMIN_TRACE_HISTORY_KIND=auto
# RAG_ADMIN_TRACE_POSTGRES_URL_ENV=RAG_DATABASE_URL
# RAG_ADMIN_TRACE_POSTGRES_SCHEMA=rag_core
# RAG_ADMIN_TRACE_HISTORY_DIR=/app/.rag/admin-traces
# RAG_ADMIN_TIMEOUT_MS=12000

RAG_INDEX_KIND=json_file
RAG_INDEX_PATH=/data/index.json
RAG_INDEX_AUTOSAVE=true
RAG_INDEX_PRETTY=false

# Production storage target. Apply deploy/postgres/001_core_storage.sql first,
# then set RAG_INDEX_KIND=postgres and provide the connection string directly
# or through a secret env indirection.
# RAG_INDEX_KIND=postgres
# RAG_POSTGRES_URL_ENV=RAG_DATABASE_URL
# RAG_DATABASE_URL=postgres://rag:replace_me@postgres:5432/rag
# RAG_POSTGRES_SCHEMA=rag_core
# Persist source connector cursors, safe hashes, retry state, and delete
# tombstones in Postgres for incremental company syncs.
# RAG_SOURCE_SYNC_LEDGER_KIND=postgres

# Use "none" for keyword-only profiles, "memory" for ephemeral local vectors,
# "json_file" for local durable vectors, "postgres" for native pgvector, or
# "hosted" for Pinecone/Qdrant/Weaviate/PostgREST pgvector RPC.
RAG_VECTOR_KIND=none
# RAG_VECTOR_PATH=/data/vectors.json
# RAG_VECTOR_DIMENSIONS=1536
# Production pgvector path, using the same RAG_DATABASE_URL/RAG_POSTGRES_SCHEMA
# values as the Postgres document/chunk index.
# RAG_VECTOR_KIND=postgres
# RAG_VECTOR_DIMENSIONS=1536

# Visual vectors are separate from text vectors. Use "none" unless the project
# configures a trusted visual embedding provider or injects a VisualEmbeddingAdapter,
# and parser extensions emit visual assets. Supported kinds: none, memory,
# json_file, hosted.
RAG_VISUAL_VECTOR_KIND=none
# RAG_VISUAL_VECTOR_PATH=/data/visual-vectors.json
# RAG_VISUAL_VECTOR_DIMENSIONS=128
# RAG_VISUAL_VECTOR_AUTOSAVE=true
# RAG_VISUAL_VECTOR_PRETTY=false

# Hosted vector example:
# RAG_VECTOR_VENDOR=qdrant
# RAG_VECTOR_ENDPOINT=http://qdrant:6333
# RAG_VECTOR_COLLECTION=rag_points
# RAG_VECTOR_API_KEY_ENV=VECTOR_VENDOR_KEY
# VECTOR_VENDOR_KEY=replace_me
#
# Hosted visual vector example. Uses the same vendor values as RAG_VECTOR_*,
# but stores visual patch vectors separately.
# RAG_VISUAL_VECTOR_VENDOR=qdrant
# RAG_VISUAL_VECTOR_ENDPOINT=http://qdrant:6333
# RAG_VISUAL_VECTOR_COLLECTION=rag_visual_points
# RAG_VISUAL_VECTOR_NAME=visual
# RAG_VISUAL_VECTOR_API_KEY_ENV=VISUAL_VECTOR_VENDOR_KEY
# VISUAL_VECTOR_VENDOR_KEY=replace_me

RAG_MODEL_PROVIDER=json-chat
RAG_MODEL_MODEL_NAME=answer-model
RAG_MODEL_ENDPOINT=https://provider.example.test/v1/chat
RAG_MODEL_API_KEY_ENV=ANSWER_MODEL_KEY
ANSWER_MODEL_KEY=replace_me

# Optional provider examples:
# RAG_EMBEDDING_PROVIDER=indexed-embedding
# RAG_EMBEDDING_MODEL_NAME=embedding-model
# RAG_EMBEDDING_ENDPOINT=https://provider.example.test/v1/embeddings
# RAG_EMBEDDING_API_KEY_ENV=EMBEDDING_MODEL_KEY
# EMBEDDING_MODEL_KEY=replace_me
# RAG_EMBEDDING_DIMENSIONS=1536
#
# RAG_VISUAL_EMBEDDING_PROVIDER=indexed-visual-embedding
# RAG_VISUAL_EMBEDDING_MODEL_NAME=visual-embedding-model
# RAG_VISUAL_EMBEDDING_ENDPOINT=https://provider.example.test/v1/visual-embeddings
# RAG_VISUAL_EMBEDDING_API_KEY_ENV=VISUAL_EMBEDDING_MODEL_KEY
# VISUAL_EMBEDDING_MODEL_KEY=replace_me
# RAG_VISUAL_EMBEDDING_DIMENSIONS=128
#
# RAG_RERANK_PROVIDER=json-rerank
# RAG_RERANK_MODEL_NAME=rerank-model
# RAG_RERANK_ENDPOINT=https://provider.example.test/v1/rerank
# RAG_RERANK_API_KEY_ENV=RERANK_MODEL_KEY
# RERANK_MODEL_KEY=replace_me
#
# Enable the optional faithfulness judge by setting
# RAG_APP_GROUNDING_JUDGE_MODE=auto or required, then provide:
# RAG_GROUNDING_JUDGE_PROVIDER=json-grounding-judge
# RAG_GROUNDING_JUDGE_MODEL_NAME=judge-model
# RAG_GROUNDING_JUDGE_ENDPOINT=https://provider.example.test/v1/judge
# RAG_GROUNDING_JUDGE_API_KEY_ENV=GROUNDING_JUDGE_MODEL_KEY
# GROUNDING_JUDGE_MODEL_KEY=replace_me

# Optional review ticket sync. CI uses dry-run. Live mode requires an HTTPS
# webhook owned by the project, support system, or ticket-sync bridge.
# RAG_REVIEW_SYNC_MODE=dry_run
# RAG_REVIEW_SYNC_WEBHOOK_URL=https://tickets.example.test/rag-review
# RAG_REVIEW_SYNC_WEBHOOK_TOKEN_ENV=REVIEW_TICKET_WEBHOOK_TOKEN
# REVIEW_TICKET_WEBHOOK_TOKEN=replace_me
# RAG_REVIEW_SYNC_WEBHOOK_TIMEOUT_MS=10000
# RAG_REVIEW_SYNC_WEBHOOK_MAX_RETRIES=2
# RAG_REVIEW_SYNC_WEBHOOK_BACKOFF_MS=250
